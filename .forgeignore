# ============================================================================
# FORGE Suppression Register (v2)
# ============================================================================
#
# Structured suppression matching — uses rule_family + file + anchors,
# NOT title regex. Title is display-only, never used for matching.
#
# Matching precedence:
#   1. check_id (deterministic checks — strongest)
#   2. rule_family + file + line_range
#   3. rule_family + file + symbol
#   4. rule_family + file
#   5. title regex (legacy fallback only — avoid writing new ones)
#
# Rules:
#   - Every entry MUST have a `reason` field — no silent suppressions
#   - Use rule_family + file for LLM findings, check_id for deterministic
#   - Review quarterly to remove stale entries
#   - Prefer fixing the code over adding a suppression
#
# ============================================================================

version: 2
suppressions:

  # ──────────────────────────────────────────────────────────────────────────
  # FALSE POSITIVES — Scanner detecting its own detection patterns
  # ──────────────────────────────────────────────────────────────────────────
  # FORGE's deterministic checks scan for security issues in USER codebases.
  # When FORGE scans itself, the check DEFINITIONS (regex patterns, template
  # text, rule files) get flagged as if they were real vulnerabilities.
  # ──────────────────────────────────────────────────────────────────────────

  # SEC-001: remediation_items.py contains the *string* "hardcoded secrets"
  # as a check name in its fix template dictionary — not actual secrets.
  # Added: 2026-03-23
  - id: sup_001
    kind: false_positive
    match:
      check_id: "SEC-001"
    reason: "False positive: remediation_items.py contains template text referencing 'hardcoded secrets' as a check name, not actual secrets in code."

  # SEC-005: maintainability.py defines regex patterns (like _INSECURE_CRYPTO)
  # that DETECT MD5/SHA1 usage in scanned codebases. FORGE itself never uses
  # insecure crypto for password hashing.
  # Added: 2026-03-23
  - id: sup_002
    kind: false_positive
    match:
      check_id: "SEC-005"
    reason: "False positive: regex patterns that detect insecure crypto in scanned code, not actual insecure crypto usage by FORGE."

  # SEC-008: security.py defines _HTTP_HARDCODED regex to detect http:// URLs
  # in user codebases. The regex itself contains 'http://' as a pattern to match.
  # Added: 2026-03-23
  - id: sup_003
    kind: false_positive
    match:
      check_id: "SEC-008"
    reason: "False positive: security check definitions contain HTTP patterns they detect in user code, not missing HTTPS in FORGE itself."

  # SEC-012: remediation_items.py contains example text like 'password=password'
  # as remediation guidance describing what insecure defaults look like.
  # Added: 2026-03-23
  - id: sup_004
    kind: false_positive
    match:
      check_id: "SEC-012"
    reason: "False positive: template text describing insecure defaults as remediation guidance, not actual insecure default values in FORGE."

  # importlib.import_module in dimensions.py only called with hardcoded string literals.
  # No user input flows into module_path.
  # Added: 2026-03-25
  - id: sup_005
    kind: false_positive
    match:
      rule_family: command-injection
      file: "forge/evaluation/dimensions.py"
      anchor:
        symbol: _safe_import
    reason: "False positive: _safe_import() only called with hardcoded string literals (lines 217-223). No user input reaches module_path."

  # FORGE is a Python CLI tool. No JavaScript, no source maps, no browser output.
  # Added: 2026-03-26
  - id: sup_006
    kind: false_positive
    match:
      rule_family: sensitive-data-exposure
      file: "forge/**"
    reason: "False positive: FORGE is a Python CLI tool. No JavaScript build system, no source maps exist."

  # MCP server returns structured JSON to IDE clients via stdio, not browser HTML.
  # No XSS vector exists.
  # Added: 2026-03-26
  - id: sup_007
    kind: false_positive
    match:
      rule_family: xss
      file: "forge/mcp_server.py"
    reason: "False positive: MCP returns structured JSON over stdio to IDE clients. No HTML rendering surface — no XSS vector."

  # repo_url / repo_path is a local filesystem path, validated by _resolve_path().
  # Added: 2026-03-26
  - id: sup_008
    kind: false_positive
    match:
      rule_family: missing-input-validation
      file: "forge/cli.py"
      anchor:
        symbol: _resolve_path
    reason: "False positive: repo_url is a local filesystem path. Already validated by Path.resolve() and allowed-directory checks in _resolve_path()."

  # CORS rules in forge/rules/ are detection patterns for user codebases,
  # not CORS configuration in FORGE.
  # Added: 2026-03-26
  - id: sup_009
    kind: false_positive
    match:
      rule_family: cors-misconfiguration
      file: "forge/rules/**"
    reason: "False positive: CORS YAML rules in forge/rules/ are detection patterns for user codebases, not actual CORS configuration in FORGE."

  # ForgeConfig uses extra='forbid' — no DEBUG field exists or can exist.
  # Added: 2026-03-25
  - id: sup_010
    kind: false_positive
    match:
      rule_family: sensitive-data-exposure
      file: "forge/config.py"
    reason: "False positive: ForgeConfig uses extra='forbid' — unknown keys (including debug) crash validation. No debug mode configuration exists."


  # ──────────────────────────────────────────────────────────────────────────
  # NOT APPLICABLE — Checks designed for web services, not CLI tools
  # ──────────────────────────────────────────────────────────────────────────

  # MCP server returns structured JSON error responses, not raw exceptions.
  # Added: 2026-03-23
  - id: sup_011
    kind: not_applicable
    match:
      check_id: "SEC-009"
    reason: "Not applicable: MCP server returns structured JSON errors, standalone wraps in ForgeResult. No raw exceptions exposed externally."

  # Masked key display is intentional UX, not PII leakage.
  # Added: 2026-03-23
  - id: sup_012
    kind: not_applicable
    match:
      check_id: "SEC-010"
    reason: "Not applicable: masked key display (api_key[:6] + '****') is intentional UX for user confirmation, not PII in logs."

  # FORGE is a CLI tool, not a long-running web service. No health endpoint needed.
  # Added: 2026-03-23
  - id: sup_013
    kind: not_applicable
    match:
      check_id: "REL-002"
    reason: "Not applicable: FORGE is a CLI tool, not a long-running web service. No health endpoint needed."

  # CI/CD managed in parent vibe2prod repo.
  # Added: 2026-03-23
  - id: sup_014
    kind: not_applicable
    match:
      check_id: "OPS-001"
    reason: "Not applicable: CI/CD managed in parent vibe2prod repo via GitHub Actions."

  # No database in FORGE — N+1 query check doesn't apply.
  # Added: 2026-03-23
  - id: sup_015
    kind: not_applicable
    match:
      check_id: "PRF-001"
    reason: "Not applicable: FORGE has no database. Check incorrectly flags file iteration loops as N+1 query patterns."

  # In-memory graph traversal, not database queries.
  # Added: 2026-03-23
  - id: sup_016
    kind: not_applicable
    match:
      check_id: "PRF-002"
    reason: "Not applicable: no database queries exist. In-memory graph traversal misidentified as unbounded DB queries."

  # Rate limiting doesn't apply to CLI tools or MCP stdio servers.
  # Added: 2026-03-26
  - id: sup_017
    kind: not_applicable
    match:
      rule_family: missing-rate-limit
      file: "forge/**"
    reason: "Not applicable: FORGE is a CLI tool and MCP stdio server. Rate limiting is for web APIs with public endpoints."

  # FORGE is a CLI tool — --verbose is standard CLI behavior, not a production risk.
  # Added: 2026-03-25
  - id: sup_018
    kind: not_applicable
    match:
      rule_family: sensitive-data-exposure
      file: "forge/cli.py"
      anchor:
        symbol: _setup_logging
    reason: "Not applicable: --verbose is standard CLI flag behavior. FORGE is a CLI tool, not a deployed service."


  # ──────────────────────────────────────────────────────────────────────────
  # ALREADY FIXED — Checks that were addressed but still trigger
  # ──────────────────────────────────────────────────────────────────────────

  # Error handling is implemented throughout the pipeline.
  # Added: 2026-03-24
  - id: sup_019
    kind: already_fixed
    match:
      check_id: "REL-001"
    reason: "Already fixed: scan commands have try/except, discovery uses asyncio.gather(return_exceptions=True), agents use retry/skip logic."

  # Env vars are validated via Pydantic strict mode.
  # Added: 2026-03-24
  - id: sup_020
    kind: already_fixed
    match:
      check_id: "OPS-004"
    reason: "Already fixed: OPENROUTER_API_KEY validated in _check_api_key() with format check. All env vars flow through ForgeConfig Pydantic validation."


  # ──────────────────────────────────────────────────────────────────────────
  # ACCEPTED RISK — Known limitations with documented mitigations
  # ──────────────────────────────────────────────────────────────────────────

  # Some except blocks intentionally swallow errors for non-critical operations.
  # Added: 2026-03-24
  - id: sup_021
    kind: accepted_risk
    match:
      check_id: "REL-004"
    reason: "Accepted risk: non-critical operations (telemetry, config parsing) use broad except with logger.debug(). Full exception handling would break UX for optional features."

  # Pipeline orchestration has inherent complexity.
  # Added: 2026-03-24
  - id: sup_022
    kind: accepted_risk
    match:
      check_id: "MNT-002"
    reason: "Accepted risk: complexity in pipeline orchestration and scoring models is inherent to the domain."

  # Lazy imports flagged as circular — they're not.
  # Added: 2026-03-23
  - id: sup_023
    kind: accepted_risk
    match:
      check_id: "MNT-005"
    reason: "Accepted risk: deferred imports inside functions (lazy import pattern) flagged as circular. No runtime circular import exists."

  # API key stored in config with 0o600 perms. Keyring planned for v2.
  # Added: 2026-03-23
  - id: sup_024
    kind: accepted_risk
    match:
      rule_family: hardcoded-secret
      file: "forge/config_io.py"
    reason: "Accepted risk: API keys stored with 0o600 permissions. System keyring integration planned for v2. Env var override documented as secure alternative."
    expires: "2026-09-01"

  # Key resolution cascade (flag > env > config) is intentional.
  # Added: 2026-03-26
  - id: sup_025
    kind: accepted_risk
    match:
      rule_family: hardcoded-secret
      file: "forge/cli.py"
      anchor:
        symbol: _check_api_key
    reason: "Accepted risk: key resolution cascade (flag > env > config file) is intentional. Config file protected by 0o600."

  # Webhook token in config — loaded from env var at runtime.
  # Added: 2026-03-26
  - id: sup_026
    kind: accepted_risk
    match:
      rule_family: hardcoded-secret
      file: "forge/standalone.py"
    reason: "Accepted risk: webhook_token has empty default in ForgeConfig. Loaded from FORGE_WEBHOOK_TOKEN env var at runtime. Config file has 0o600 perms."

  # Error stack traces go to stderr/logs, not external callers.
  # Added: 2026-03-26
  - id: sup_027
    kind: accepted_risk
    match:
      rule_family: error-info-leak
      file: "forge/**"
    reason: "Accepted risk: tracebacks go to stderr/debug logs, not external callers. MCP returns structured JSON errors. CLI wraps in ForgeResult."


  # ──────────────────────────────────────────────────────────────────────────
  # INTENTIONAL DESIGN — Features that look like vulnerabilities
  # ──────────────────────────────────────────────────────────────────────────

  # LLM prompts include code context — this is FORGE's core function.
  # Added: 2026-03-25
  - id: sup_028
    kind: intentional
    match:
      rule_family: sensitive-data-exposure
      file: "forge/reasoners/**"
    reason: "Intentional: LLM prompts include code context for security analysis. This is FORGE's core function. Telemetry stores only summary data."

  # Webhook TLS enforced by Python's default SSL verification + config validation.
  # Added: 2026-03-25
  - id: sup_029
    kind: intentional
    match:
      rule_family: insecure-tls
      file: "forge/**"
    reason: "Intentional: webhook uses Python default SSL verification. Config enforces HTTPS for non-localhost. TLS bypass env vars disable telemetry entirely."


  # ──────────────────────────────────────────────────────────────────────────
  # TEST FIXTURES — Intentionally vulnerable code for testing
  # ──────────────────────────────────────────────────────────────────────────

  # Golden test codebases contain intentional vulnerabilities.
  # Added: 2026-03-20
  - id: sup_030
    kind: test_fixture
    match:
      file: "tests/golden/**"
    reason: "Test fixtures: golden codebases are intentionally insecure for validating FORGE detection accuracy."

  # Test files may contain intentional secrets/vulnerabilities.
  # Added: 2026-03-20
  - id: sup_031
    kind: test_fixture
    match:
      file: "tests/**"
      category: security
    reason: "Test fixtures: test files contain intentional secrets/vulnerabilities for validation."
