# .forgeignore — Suppression rules for FORGE self-scan
# Each rule requires a reason field documenting why it's suppressed.

# AST analysis code iterates files in loops — not actual database N+1 queries
- pattern: "N\\+1 query"
  reason: "AST walker code iterates source files in loops, not DB queries"

# CI/CD exists in GitHub remote (private Actions workflows), not committed to repo
- pattern: "No CI/CD"
  reason: "GitHub Actions workflows exist in remote, not committed to source"

# Complexity in reasoner/prompt modules is inherent to the domain
- pattern: "cyclomatic complexity"
  path: "forge/reasoners/**"
  reason: "Discovery reasoners have complex LLM response parsing — inherent to domain"

- pattern: "cyclomatic complexity"
  path: "forge/prompts/**"
  reason: "Prompt builders have complex string assembly — inherent to domain"

# Deep nesting in pipeline orchestration is expected
- pattern: "Deep nesting"
  path: "forge/phases.py"
  reason: "Pipeline orchestration has nested try/except + conditional paths"

- pattern: "Deep nesting"
  path: "forge/reasoners/**"
  reason: "Response parsing requires nested error handling"

# Circular import in graph module is a lazy import inside a function (TYPE_CHECKING-style)
- pattern: "Circular import"
  path: "forge/graph/**"
  reason: "language_extractors.py imports builder._get_language inside a function — lazy import, no runtime cycle"

# Golden test codebases are intentionally vulnerable — used as FORGE test fixtures
- pattern: ".*"
  path: "tests/golden/**"
  reason: "Golden codebases are intentionally insecure test fixtures"

# Test configuration files contain intentional test secrets
- pattern: ".*secret.*|.*hardcoded.*|.*ASVS.*FAIL.*"
  path: "tests/**"
  category: security
  reason: "Test fixtures contain intentional secrets/vulnerabilities for validation"

# Setup wizard is a local CLI tool — no debug mode to disable (CWE-489)
- pattern: "Debug mode enablement"
  path: "setup_wizard.py"
  reason: "False positive: setup_wizard.py is a local CLI tool, not a web server. There is no debug mode to disable."

# subprocess.run() with list-form args is safe from shell injection (CWE-78)
- pattern: "User input to subprocess"
  path: "setup_wizard.py"
  reason: "False positive: code uses list-form subprocess.run() which is immune to shell injection. The auditor's own suggested fix confirms this."

# SQL injection false positive — no SQL database in this codebase (F-822bffaa)
- id: "F-822bffaa"
  pattern: "SQL injection"
  reason: "False positive: FORGE is an LLM orchestration tool with no SQL database. All data is file-based JSON."

# Debug mode is intentional CLI --verbose flag, not a web server debug mode (F-9b54a196)
- id: "F-9b54a196"
  pattern: "Debug mode"
  path: "forge/cli.py"
  reason: "False positive: CLI tool uses --verbose flag for debug logging, not a web server debug mode. This is intentional and expected."

# SEC-001: remediation_items.py contains the string "hardcoded secrets" as check name/template text
- check_id: "SEC-001"
  path: "forge/**/remediation_items.py"
  reason: "Template text referencing 'hardcoded secrets' as a check name, not actual secrets."

# SEC-005: maintainability.py has regex patterns for detecting insecure crypto in user code
- check_id: "SEC-005"
  path: "forge/**/maintainability.py"
  reason: "Regex patterns that detect insecure crypto in scanned code, not actual insecure crypto usage."

# SEC-008: security.py references HTTPS patterns it detects, not missing HTTPS in FORGE
- check_id: "SEC-008"
  path: "forge/**/security.py"
  reason: "Security check definitions reference HTTPS patterns they detect, not missing HTTPS in FORGE itself."

# SEC-009: FORGE is a CLI tool — MCP server returns structured JSON, standalone is internal
- check_id: "SEC-009"
  path: "forge/mcp_server.py"
  reason: "MCP server returns structured JSON error responses, not raw exceptions. CLI tool, not a web service."

- check_id: "SEC-009"
  path: "forge/standalone.py"
  reason: "Internal module used by CLI and MCP server. Errors are caught and wrapped in structured responses."

# SEC-010: Masked key display is intentional UX, not PII leakage
- check_id: "SEC-010"
  path: "forge/setup_wizard.py"
  reason: "Masked key display (api_key[:6] + '****') is intentional UX for user confirmation, not PII leakage."

# SEC-012: remediation_items.py contains template text about insecure defaults as guidance
- check_id: "SEC-012"
  path: "forge/**/remediation_items.py"
  reason: "Template text about 'insecure defaults' as remediation guidance for scanned code, not actual insecure defaults."

# REL-002: FORGE is a CLI tool and MCP server, not a web service
- check_id: "REL-002"
  pattern: "No health check endpoint"
  reason: "FORGE is a CLI tool and MCP server, not a long-running web service. No health endpoint needed."

# PRF-001: FORGE has no database — for loops near function calls are not N+1 queries
- check_id: "PRF-001"
  path: "forge/cli.py"
  reason: "No database in FORGE. Check incorrectly flags for loops near function calls as N+1 query patterns."

# PRF-002: No database queries in these files — pattern matching false positive
- check_id: "PRF-002"
  path: "forge/**/report_dependency_graph.py"
  reason: "No database queries exist. Graph traversal code is misidentified as unindexed DB queries."

- check_id: "PRF-002"
  path: "forge/**/context.py"
  reason: "No database queries exist. Pattern context code is misidentified as unindexed DB queries."

- check_id: "PRF-002"
  path: "forge/**/worker_utils.py"
  reason: "No database queries exist. Swarm worker utilities are misidentified as unindexed DB queries."

# OPS-001: CI/CD is in the parent vibe2prod repo via GitHub Actions
- check_id: "OPS-001"
  pattern: "No CI/CD"
  reason: "FORGE uses GitHub Actions for CI/CD via the parent vibe2prod repo. The forge-engine repo itself doesn't need its own CI config."

# Config key storage: keys stored with 0o600 permissions. Keyring integration planned for v2.
- pattern: "plaintext.*API key|API key.*plaintext|encrypt.*key.*at rest"
  path: "forge/setup_wizard.py"
  reason: "Keys are stored with 0o600 permissions. System keyring integration planned for v2. Environment variable override is documented as the secure alternative."

- pattern: "hardcoded.*API key.*env|API key.*hardcoded.*fallback"
  path: "forge/cli.py"
  reason: "The code reads keys from env vars or config file — it does not hardcode keys. The finding misidentifies the key resolution cascade as hardcoding."

# LLM prompts intentionally include code context for security analysis
- pattern: "Sensitive data.*logged.*agent invocations|data may be logged"
  reason: "LLM prompts intentionally include code context for security analysis. Telemetry stores only summary data (model, tokens, cost, latency), not full prompts or code snippets."

# Webhook TLS is enforced by urllib default SSL verification + config HTTPS validator
- pattern: "webhook.*TLS|TLS.*webhook"
  reason: "Webhook POST uses urllib.request.urlopen with default SSL verification (Python 3.4+). Config validates HTTPS-only for non-localhost."

# Debug mode controlled via CLI --verbose flag, documented in deployment guide
- pattern: "Debug mode.*implicitly|debug mode.*logging"
  reason: "Debug logging controlled via CLI --verbose flag. Default is INFO level. No debug mode in production. FORGE_DEBUG documented in deployment guide."

# Config file integrity — HMAC is over-engineered for a local CLI tool
- pattern: "API key.*compromised config|config file.*integrity"
  reason: "CLI config file is protected by 0o600 permissions. HMAC integrity checking adds complexity without meaningful security benefit for a local CLI tool. Environment variable override is the secure alternative."

# REL-001: Error handling at API boundaries — already implemented
- check_id: "REL-001"
  path: "forge/cli.py"
  reason: "scan/fix commands already wrap asyncio.run() in try/except with structured error output (lines 284-288, 334-338)."

- check_id: "REL-001"
  path: "forge/reasoners/discovery.py"
  reason: "Security auditor uses asyncio.gather(return_exceptions=True) with per-pass error handling. Codebase analyst errors propagate to pipeline-level handler."

- check_id: "REL-001"
  path: "forge/reasoners/hive_discovery.py"
  reason: "Delegates to HiveOrchestrator which has its own error handling. Errors propagate to pipeline-level try/except in phases.py."

# MNT-002: High cyclomatic complexity — inherent to domain logic
- check_id: "MNT-002"
  path: "forge/phases.py"
  reason: "Pipeline orchestration has inherent complexity from multi-phase coordination, error recovery, and state management. Already uses extracted helpers."

- check_id: "MNT-002"
  path: "forge/standalone.py"
  reason: "Standalone dispatcher complexity comes from registry resolution and config merging. Already factored into separate methods."

- check_id: "MNT-002"
  path: "forge/conventions/formatter.py"
  reason: "Convention formatting builds prompt strings from multiple optional sections. Inherent to the domain — each section is a simple conditional block."

- check_id: "MNT-002"
  path: "forge/evaluation/aivss_detector.py"
  reason: "AIVSS detection aggregates multiple regex-based checks across file categories. Complexity is inherent to the scoring model dimensions."

# OPS-004: Env validation — already implemented or not applicable
- check_id: "OPS-004"
  path: "forge/cli.py"
  reason: "OPENROUTER_API_KEY validated in _check_api_key() with format check and clear error messages. Config file fallback also supported."

- check_id: "OPS-004"
  path: "forge/mcp_server.py"
  reason: "OPENROUTER_API_KEY checked at scan time with structured error response. VIBE2PROD_API_KEY is optional with graceful fallback."

- check_id: "OPS-004"
  path: "forge/phases.py"
  reason: "FORGE_NODE_ID uses os.getenv with sensible default. No other env vars consumed directly — all config flows through ForgeConfig."
